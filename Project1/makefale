CXX = g++
CXXFLAGS = -Wall -std=c++11
TARGET = program
OBJS = main.o Refrigerator.o Database.o

all: $(TARGET)

$(TARGET): $(OBJS)
	$(CXX) $(CXXFLAGS) -o $(TARGET) $(OBJS)

main.o: laba1.cpp Refrigerator.h
	$(CXX) $(CXXFLAGS) -c laba1.cpp

Refrigerator.o: pom.cpp Refrigerator.h
	$(CXX) $(CXXFLAGS) -c pom.cpp

Database.o: Source.cpp Refrigerator.h
	$(CXX) $(CXXFLAGS) -c Source.cpp

clean:
	rm -f $(OBJS) $(TARGET) data.dat

run: $(TARGET)
	./$(TARGET)
